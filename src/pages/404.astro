---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Home, ArrowLeft } from 'lucide-react';

const seo = {
  title: '404 - Página no encontrada | Erwing Solorzano',
  description: 'La página que buscas no existe. Vuelve al inicio para explorar el portafolio.',
};
---

<BaseLayout seo={seo}>
  <div class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <div class="mb-8">
        <h1 class="text-9xl font-bold text-white/10">404</h1>
      </div>
      
      <h2 class="text-3xl font-semibold text-white mb-4">
        Página no encontrada
      </h2>
      
      <p class="text-lg text-slate-300 mb-8 max-w-md mx-auto">
        La página que buscas no existe o fue movida. Puedes volver al inicio para seguir explorando.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center px-6 py-3 rounded-xl bg-green-400 text-black font-medium transition-colors hover:bg-green-300"
        >
          <Home class="w-5 h-5 mr-2" />
          Ir al inicio
        </a>
        
        <button
          onclick="history.back()"
          class="inline-flex items-center px-6 py-3 rounded-xl border border-white/10 bg-white/5 text-white font-medium transition-colors hover:bg-white/10"
        >
          <ArrowLeft class="w-5 h-5 mr-2" />
          Volver atrás
        </button>
      </div>
    </div>
  </div>
</BaseLayout>
